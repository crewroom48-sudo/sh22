{
  "expo": {
    "name": "Shift Checklist",
    "slug": "preshift",
    "version": "1.0.0",

    "orientation": "portrait",

    "icon": "./r.png",

    "userInterfaceStyle": "light",

    "newArchEnabled": false,

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.mcdesc.preshift",

      "permissions": [
        "NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "RECEIVE_BOOT_COMPLETED"
      ],

      "adaptiveIcon": {
        "foregroundImage": "./r.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true
    },

    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow access to photos",
          "cameraPermission": "Allow access to camera"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": "00422f5f-3a47-4234-b03f-34bfa1450462"
      }
    }
  }
}
